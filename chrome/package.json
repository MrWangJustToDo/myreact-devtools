{
  "name": "my-react-devtools",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:web": "NEXT_PUBLIC_MODE=web node server.mjs",
    "dev:socket": "NEXT_PUBLIC_MODE=socket node server.mjs",
    "dev:local": "NEXT_PUBLIC_MODE=local next dev",
    "dev:extension": "npm-watch",
    "build": "next build",
    "build:local": "NEXT_PUBLIC_MODE=local next build",
    "start": "next start",
    "lint": "next lint",
    "build:extension": "next build --webpack && npm run lint:build",
    "lint:build": "mv out/_next out/assets && gsed -i 's/\\/_next/\\/assets/g' out/**.html && gsed -i 's/\\/_next/\\/assets/g' out/assets/static/chunks/**.js && gsed -i 's/\\/_next/\\/assets/g' out/assets/static/css/**.css",
    "package": "npm run build:extension && zip -r packages/$(date -u +\"%Y-%m-%dT%H:%M:%SZ\").zip out"
  },
  "dependencies": {
    "@heroui/react": "^2.7.5",
    "@my-react-devtool/bridge": "workspace:*",
    "@my-react-devtool/core": "workspace:*",
    "@my-react/react": "^0.3.22",
    "@my-react/react-dom": "^0.3.22",
    "@my-react/react-reconciler": "^0.3.22",
    "allotment": "^1.20.5",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.545.0",
    "next": "^16.2.0",
    "next-themes": "^0.4.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-virtuoso": "^4.18.3",
    "reactivity-store": "^0.4.0",
    "shiki": "^1.29.2"
  },
  "devDependencies": {
    "@my-react/react-refresh": "^0.3.22",
    "@my-react/react-refresh-tools": "^0.0.33",
    "@types/chrome": "^0.0.304",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.4.27",
    "babel-plugin-react-compiler": "^1.0.0",
    "cors": "^2.8.6",
    "eslint": "^9",
    "eslint-config-next": "^16.2.0",
    "express": "^4.22.1",
    "npm-watch": "^0.13.0",
    "postcss": "^8.5.8",
    "react-compiler-runtime": "^1.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwindcss": "^3.4.19"
  },
  "watch": {
    "build:extension": {
      "patterns": [
        "./src/**",
        "./public/**"
      ],
      "ignore": [
        "out",
        "node_modules",
        ".next"
      ],
      "extensions": [
        "js",
        "json",
        "lock",
        "tsx",
        "ts"
      ]
    }
  }
}